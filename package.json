{
  "name": "swoogo-selfcheckin",
  "version": "1.0.0",
  "description": "Express service for Swoogo self check-in.",
  "main": "src/server.js",
  "scripts": {
    "dev": "node --watch src/server.js",
    "print:worker": "node workers/print-worker/index.js",
    "print:worker:watch": "node workers/print-worker/index.js --mode=watch --ui",
    "setup:firestore": "node scripts/setup-firestore.js",
    "start": "node src/server.js",
    "test": "node --test test/*.test.js workers/print-worker/test/*.test.js",
    "test:api": "node --test test/*.test.js",
    "test:print": "node --test workers/print-worker/test/*.test.js",
    "test:web": "npm --prefix web test"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luisleao/swoogo-selfcheckin.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/luisleao/swoogo-selfcheckin/issues"
  },
  "homepage": "https://github.com/luisleao/swoogo-selfcheckin#readme",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "firebase-admin": "^14.0.0"
  }
}
